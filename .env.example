# ---------------------------------------------------------------------------
# Supabase (required for persistence + realtime)
# Create a project at https://supabase.com and copy the values below.
# NOTE: Use the bare project URL — do NOT append /rest/v1/.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is used only on the server (API routes / orchestrator).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# LLM for the Itinerary Agent (OpenAI-compatible — works with OpenRouter)
# - OpenAI:     OPENAI_BASE_URL=https://api.openai.com/v1, OPENAI_MODEL=gpt-4o-mini
# - OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1, OPENAI_MODEL=openai/gpt-4o-mini
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-llm-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# LiteAPI (real flight + hotel data) — https://dashboard.liteapi.travel
# Get a sandbox key (sand_...) or production key (prod_...) from the dashboard.
# REQUIRED — the Flight and Hotel agents use live data only (no sample data).
# ---------------------------------------------------------------------------
LITEAPI_API_KEY=your-liteapi-key
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
